{
  "name": "eslint-custom-rules",
  "version": "1.2.0",
  "description": "Custom ESLint rules to enforce functional programming patterns and best practices for the Bunpress project",
  "main": "index.js",
  "files": [
    "index.js",
    "rules/*.js"
  ],
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "author": "BunPress Team",
  "license": "MIT",
  "keywords": [
    "eslint",
    "eslintplugin",
    "functional",
    "immutable",
    "dry",
    "code-quality",
    "dead-code",
    "unused-exports"
  ],
  "peerDependencies": {
    "eslint": ">=6"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jest-circus": "^29.7.0"
  },
  "engines": {
    "node": ">=14.16"
  }
}
